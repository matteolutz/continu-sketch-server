{
  "name": "continu-sketch-server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prisma-generate": "prisma generate",
    "dev": "nodemon -r dotenv/config -w src/server -x tsx src/server/main.ts",
    "start-prod": "prisma migrate deploy && prisma generate && cross-env NODE_ENV=production tsx src/server/main.ts",
    "build": "vite build"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "cross-env": "^7.0.3",
    "express": "^5.1.0",
    "pg": "^8.20.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite-express": "*"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.2",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "dotenv": "^17.3.1",
    "nodemon": "^3.1.10",
    "prisma": "^7.4.2",
    "vite": "^6.3.3"
  }
}
